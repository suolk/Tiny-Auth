{
    "manifest_version": 3,
    "name": "2FA-Auth-Lite",
    "version": "1.0.1",
    "description": "Generate TOTP codes for two-factor authentication.",
    "icons": {
        "64": "icons/icon64x64.png"
    },
    "action": {
        "default_title": "2FA-Auth-Lite",
        "default_popup": "popup.html"
    },
    "permissions": [
        "storage",
        "clipboardWrite",
        "activeTab"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "tiny-auth@suolk.com",
            "strict_min_version": "142.0",
            "data_collection_permissions": {
                "required": [
                    "none"
                ]
            }
        },
        "gecko_android": {
            "strict_min_version": "142.0"
        }
    }
}